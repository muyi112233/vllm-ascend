+
+                if rfork_worker.rfork_seed is None:
                     raise RuntimeError("seed is not available.")
 
                 with target_device:
@@ -184,7 +195,7 @@ class RForkModelLoader(BaseModelLoader):
                 self.load_config.model_loader_extra_config = {}
 
