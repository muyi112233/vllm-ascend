@@ -237,6 +238,20 @@ class KVCacheTaskTracker:
             self.finished_requests.clear()
         return finished_requests
 
+    def update_load_error_block_ids(self, block_ids: list[int]) -> None:
+        """Record local blocks that failed to load from a remote worker."""
+        if not block_ids:
+            return
+        with self.done_task_lock:
+            self.load_error_block_ids.update(block_ids)
+
+    def get_and_clear_load_error_block_ids(self) -> set[int]:
+        """Get and clear local blocks that failed to load."""
+        with self.done_task_lock:
+            load_error_block_ids = self.load_error_block_ids.copy()
+            self.load_error_block_ids.clear()
+        return load_error_block_ids
+
