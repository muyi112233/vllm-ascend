         self._helper = YuanrongHelper(Blob, DeviceBlobList)
         self._ds_set_param = SetParam()
@@ -114,6 +144,19 @@ class YuanrongBackend(Backend):
             enable_remote_h2d=self.config.enable_remote_h2d,
         )
         self._hetero_client.init()
